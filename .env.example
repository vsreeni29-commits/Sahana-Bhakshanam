# Prototype reviewers can keep demo mode on. Production must set this to false
# and configure all three Twilio Verify values below.
OTP_DEMO_MODE=false
# Optional local-only six-digit code. Never expose or enable this on a public deployment.
OTP_DEMO_CODE=
OTP_HASH_SECRET=replace-with-a-long-random-secret
# Example format: country code followed by the registered mobile number.
CHEF_PHONE_E164=
# Optional comma-separated allowlist. Keep real numbers in hosted secrets only.
CHEF_PHONE_E164_LIST=
SESSION_COOKIE_SECURE=true

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Point this signed webhook at a WhatsApp Business Cloud API relay/provider.
ORDER_RELAY_URL=
ORDER_RELAY_SECRET=
